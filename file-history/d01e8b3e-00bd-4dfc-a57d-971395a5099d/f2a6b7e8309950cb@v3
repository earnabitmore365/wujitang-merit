# ==================== 配置 ====================

BASE_URL = 'https://www.bitmex.com'
API_BASE = '/api/v1'

SYMBOL_MAP = {
    'BTC': 'XBTUSDT', 'ETH': 'ETHUSDT', 'SOL': 'SOLUSDT',
    'XRP': 'XRPUSDT', 'ADA': 'ADAUSDT', 'DOT': 'DOTUSDT',
    'AVAX': 'AVAXUSDT', 'LINK': 'LINKUSDT', 'DOGE': 'DOGEUSD',
}

# 运行中的策略
STRATEGIES = [
    {
        'name': 'mean_reversion_mirror',
        'coin': 'ETH',
        'interval': '15m',
        'margin': '$100',
        'log': os.path.join(_HERE, 'bitmex_race_eth.log'),
    },
