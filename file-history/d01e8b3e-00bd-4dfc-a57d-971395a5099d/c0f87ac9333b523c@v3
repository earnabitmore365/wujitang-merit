#!/usr/bin/env python3
"""
HyperLiquid WebSocket

HyperLiquid WebSocket 客户端
实时获取价格更新
"""

import json
import logging
import threading
import time
from typing import Callable, Dict, Optional

try:
    import websockets
    WEBSOCKETS_AVAILABLE = True
except ImportError:
    WEBSOCKETS_AVAILABLE = False

__all__ = ['HyperLiquidWebSocket', 'create_websocket']


class HyperLiquidWebSocket:
    """HyperLiquid WebSocket 客户端

    Usage:
        # 回调方式
        def on_message(data):
            print(data)

        ws = HyperLiquidWebSocket(
            endpoint="wss://api.hyperliquid-testnet.xyz/ws",
            on_message=on_message,
        )
        ws.connect()

        # 订阅价格
        ws.subscribe("BTC")
        ws.subscribe("ETH")

    Attributes:
        connected: 是否已连接
        prices: 最新价格缓存
    """

    def __init__(
        self,
        endpoint: str,
        on_message: Callable[[dict], None] = None,
    ):
        """初始化

        Args:
            endpoint: WebSocket 端点
            on_message: 消息回调函数
        """
        self.endpoint = endpoint
        self.on_message = on_message

        # 连接状态
        self._connected = False
        self._ws = None
        self._thread = None
        self._running = False

        # 价格缓存
        self.prices: Dict[str, float] = {}

        # 盘口缓存: {coin: {'bids': [(px, sz, n), ...], 'asks': [...], 'time': ms}}
        self.orderbooks: Dict[str, dict] = {}

        # 订阅的币种
        self._subscribed_coins: set = set()

        # 订阅的盘口币种
        self._subscribed_orderbooks: set = set()

        # 当前运行的 event loop（供 _send 跨线程调用）
        self._loop = None

        # 锁
        self._lock = threading.Lock()

        # 日志
        self.logger = logging.getLogger("HyperLiquidWebSocket")

    # ==================== 连接管理 ====================

    def connect(self) -> bool:
        """连接 WebSocket

        Returns:
            bool: 是否连接成功
        """
        if not WEBSOCKETS_AVAILABLE:
            self.logger.error("websockets 库未安装")
            return False

        if self._connected:
            return True

        try:
            # 启动后台线程处理 WebSocket
            self._running = True
            self._thread = threading.Thread(target=self._run, daemon=True)
            self._thread.start()

            # 等待连接建立
            for _ in range(10):
                time.sleep(0.5)
                if self._connected:
                    self.logger.debug(f"WebSocket 已连接: {self.endpoint}")
                    return True

            self.logger.warning("WebSocket 连接超时")
            return self._connected

        except Exception as e:
            self.logger.error(f"WebSocket 连接失败: {e}")
            self._running = False
            return False

    def disconnect(self):
        """断开连接"""
        self._running = False
        self._connected = False

        try:
            if self._ws and self._loop and not self._loop.is_closed():
                try:
                    future = asyncio.run_coroutine_threadsafe(
                        self._ws.close(), self._loop
                    )
                    future.result(timeout=2)
                except Exception:
                    pass
        except Exception as e:
            self.logger.debug(f"关闭连接: {e}")

        self._ws = None
        if self._thread and self._thread.is_alive():
            self._thread.join(timeout=2)

        self.logger.debug("WebSocket 已断开")

    # ==================== 订阅管理 ====================

    def subscribe(self, coin: str):
        """订阅币种价格

        Args:
            coin: 币种名称（如 "BTC"）
        """
        with self._lock:
            self._subscribed_coins.add(coin)

        if self._connected and self._ws:
            self._send({
                "method": "subscribe",
                "subscription": {
                    "type": "trades",
                    "coin": coin,
                }
            })

    def unsubscribe(self, coin: str):
        """取消订阅币种

        Args:
            coin: 币种名称
        """
        with self._lock:
            self._subscribed_coins.discard(coin)

        if self._connected and self._ws:
            self._send({
                "method": "unsubscribe",
                "subscription": {
                    "type": "trades",
                    "coin": coin,
                }
            })

    def subscribe_orderbook(self, coin: str):
        """订阅币种盘口（l2Book）

        Args:
            coin: 币种名称（如 "BTC"）
        """
        with self._lock:
            self._subscribed_orderbooks.add(coin)

        if self._connected and self._ws:
            self._send({
                "method": "subscribe",
                "subscription": {
                    "type": "l2Book",
                    "coin": coin,
                }
            })

    def unsubscribe_orderbook(self, coin: str):
        """取消订阅盘口

        Args:
            coin: 币种名称
        """
        with self._lock:
            self._subscribed_orderbooks.discard(coin)

        if self._connected and self._ws:
            self._send({
                "method": "unsubscribe",
                "subscription": {
                    "type": "l2Book",
                    "coin": coin,
                }
            })

    def get_orderbook(self, coin: str) -> Optional[dict]:
        """获取最新盘口数据

        Args:
            coin: 币种名称

        Returns:
            dict: {'bids': [(px, sz, n), ...], 'asks': [...], 'time': ms}
                  获取失败返回 None
        """
        with self._lock:
            return self.orderbooks.get(coin)

    # ==================== 价格获取 ====================

    def get_price(self, coin: str) -> Optional[float]:
        """获取当前价格

        Args:
            coin: 币种名称

        Returns:
            float: 当前价格，获取失败返回 None
        """
        with self._lock:
            return self.prices.get(coin)

    def get_all_prices(self) -> Dict[str, float]:
        """获取所有订阅币种的价格

        Returns:
            Dict[str, float]: 价格字典
        """
        with self._lock:
            return self.prices.copy()

    # ==================== 私有方法 ====================

    def _run(self):
        """运行循环"""
        import asyncio

        while self._running:
            try:
                # 创建新的事件循环
                loop = asyncio.new_event_loop()
                asyncio.set_event_loop(loop)

                loop.run_until_complete(self._connect_and_listen())

            except Exception as e:
                if self._running:
                    self.logger.warning(f"WebSocket 连接断开，3秒后重连...: {e}")
                    time.sleep(3)
                else:
                    break

    async def _connect_and_listen(self):
        """连接并监听消息"""
        self._loop = asyncio.get_running_loop()
        try:
            async with websockets.connect(
                self.endpoint,
                ping_interval=30,
                ping_timeout=10,
            ) as ws:
                self._ws = ws
                self._connected = True
                self.logger.debug(f"WebSocket 连接成功: {self.endpoint}")

                # 重新订阅之前订阅的币种
                with self._lock:
                    coins = list(self._subscribed_coins)
                    ob_coins = list(self._subscribed_orderbooks)

                for coin in coins:
                    await ws.send(json.dumps({
                        "method": "subscribe",
                        "subscription": {
                            "type": "trades",
                            "coin": coin,
                        }
                    }))

                for coin in ob_coins:
                    await ws.send(json.dumps({
                        "method": "subscribe",
                        "subscription": {
                            "type": "l2Book",
                            "coin": coin,
                        }
                    }))

                # 监听消息
                async for message in ws:
                    if not self._running:
                        break
                    self._handle_message(message)

        except websockets.exceptions.ConnectionClosed as e:
            self.logger.warning(f"WebSocket 连接关闭: {e}")
        except Exception as e:
            self.logger.error(f"WebSocket 错误: {e}")
        finally:
            self._connected = False

    def _handle_message(self, message: str):
        """处理消息

        Args:
            message: WebSocket 消息
        """
        try:
            data = json.loads(message)

            channel = data.get("channel", "")

            if channel == "l2Book":
                # === 盘口数据 ===
                book_data = data.get("data", {})
                coin = book_data.get("coin")
                levels = book_data.get("levels", [])

                if coin and len(levels) == 2:
                    bids = [(float(l['px']), float(l['sz']), int(l.get('n', 0)))
                            for l in levels[0]]
                    asks = [(float(l['px']), float(l['sz']), int(l.get('n', 0)))
                            for l in levels[1]]
                    with self._lock:
                        self.orderbooks[coin] = {
                            'bids': bids,
                            'asks': asks,
                            'time': book_data.get('time', 0),
                        }

            elif "data" in data:
                # === 交易数据 ===
                trades = data["data"]
                if isinstance(trades, list):
                    for trade in trades:
                        coin = trade.get("coin")
                        price = trade.get("px")

                        if coin and price:
                            try:
                                price_float = float(price)
                                with self._lock:
                                    self.prices[coin] = price_float
                            except (ValueError, TypeError):
                                pass

            # 调用回调
            if self.on_message:
                self.on_message(data)

        except Exception as e:
            self.logger.debug(f"处理消息失败: {e}")

    def _send(self, message: dict):
        """发送消息（线程安全，使用 run_coroutine_threadsafe）

        Args:
            message: 消息字典
        """
        if self._connected and self._ws and self._loop:
            try:
                future = asyncio.run_coroutine_threadsafe(
                    self._ws.send(json.dumps(message)),
                    self._loop,
                )
                # fire-and-forget：subscribe 是通知型消息，不阻塞等确认
                # 发送失败时断线重连会自动重新订阅
            except Exception as e:
                self.logger.debug(f"发送消息失败: {e}")

    # ==================== 属性 ====================

    @property
    def is_connected(self) -> bool:
        """是否已连接"""
        return self._connected

    def __repr__(self) -> str:
        """字符串表示"""
        status = "已连接" if self._connected else "未连接"
        return f"<HyperLiquidWebSocket: {status}>"


# ==================== 工厂函数 ====================

def create_websocket(
    testnet: bool = True,
    on_message: Callable[[dict], None] = None,
) -> HyperLiquidWebSocket:
    """创建 WebSocket 实例

    Args:
        testnet: 是否使用测试网
        on_message: 消息回调

    Returns:
        HyperLiquidWebSocket: WebSocket 实例
    """
    endpoint = (
        "wss://api.hyperliquid-testnet.xyz/ws" if testnet
        else "wss://api.hyperliquid.xyz/ws"
    )

    return HyperLiquidWebSocket(
        endpoint=endpoint,
        on_message=on_message,
    )
