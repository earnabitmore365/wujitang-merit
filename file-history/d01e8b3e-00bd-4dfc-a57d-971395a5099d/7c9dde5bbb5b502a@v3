#!/usr/bin/env python3
"""trader_bot.py — Telegram 命令查询 bot.

通过 Telegram 命令查询交易状态、PnL、历史交易。
长轮询 getUpdates，在 Trader Report thread 里响应命令。

命令：
    /status [name]  — 全部策略状态 / 模糊匹配
    /pnl            — 按策略类型查今日 PnL（按钮选择）
    /trades         — 按策略类型查最近交易（按钮选择）
    /summary        — 总体统计
    /win            — 策略 PnL 排名
    /help           — 帮助

@see trader_report.py — 自动通知（开仓/平仓/TTP/熔断）
@see trade_logger.py — SQLite 数据源
"""

from __future__ import annotations

import contextlib
import json
import logging
import os
import sqlite3
import sys
import time
import urllib.request
from datetime import datetime, timezone
from typing import Any

_p = os.path.dirname(os.path.abspath(__file__))
while _p != os.path.dirname(_p) and not os.path.exists(os.path.join(_p, '.wuji-root')):
    _p = os.path.dirname(_p)
if _p not in sys.path:
    sys.path.insert(0, _p)
from path_config import ROOT, DATA_DIR, REPORT_DIR, SRC_DIR  # noqa: E402
if SRC_DIR not in sys.path:
    sys.path.insert(0, SRC_DIR)

logger = logging.getLogger("TraderBot")

# 从 .env 读取
BOT_TOKEN = os.getenv("TELEGRAM_BOT_TOKEN", "")
CHAT_ID = os.getenv("TELEGRAM_CHAT_ID", "")
THREAD_ID = int(os.getenv("TELEGRAM_TRADER_THREAD_ID", "12030"))
TG_API_BASE = f"https://api.telegram.org/bot{BOT_TOKEN}"

# 数据文件路径
DB_PATH = os.path.join(REPORT_DIR, "live_trades.db")
STATES_PATH = os.path.join(ROOT, "trading", "strategy_states.json")
DB_NOT_FOUND = "❌ 数据库未找到"
TRADES_SELECT_COLS = (
    "strategy_id, side, entry_price, exit_price,"
    " pnl, fee, close_reason, close_time"
)


def pnl_emoji(pnl: float) -> str:
    return "💰" if pnl >= 0 else "💸"


# 策略类型（从 team_config 动态获取）
try:
    from team_config import TEAM
    STRATEGY_TYPES = sorted({cfg.strategy for cfg in TEAM})
    _iv_order = {"1m": 1, "5m": 2, "15m": 3, "30m": 4, "1h": 5}
    INTERVALS = sorted(
        {cfg.interval for cfg in TEAM},
        key=lambda x: _iv_order.get(x, 99),
    )
except Exception:
    TEAM = []
    STRATEGY_TYPES = [
        "mean_reversion", "bb_squeeze", "order_block",
        "proc", "rsi_reversal", "williams_fast",
        "advanced_kline_echo", "smc_real",
    ]
    INTERVALS = ["1m", "5m", "15m", "30m", "1h"]


class TraderBot:
    """Telegram 命令查询 bot."""

    def __init__(self) -> None:
        self._last_update_id = 0

    def run(self) -> None:
        """主循环：长轮询."""
        logger.info("TraderBot 启动，等待命令...")
        while True:
            try:
                updates = self._get_updates()
                for u in updates:
                    self._handle_update(u)
            except Exception:
                logger.exception("轮询异常")
            time.sleep(1)

    # ========== Telegram API ==========

    def _get_updates(self) -> list[Any]:
        """获取新消息."""
        url = (f"{TG_API_BASE}/getUpdates"
               f"?offset={self._last_update_id + 1}&timeout=30"
               '&allowed_updates=["message","callback_query"]')
        try:
            req = urllib.request.Request(url)
            with urllib.request.urlopen(req, timeout=35) as resp:
                data = json.loads(resp.read().decode())
                result: list[Any] = data.get("result", [])
                return result
        except Exception:
            return []

    def _send(
        self, text: str,
        chat_id: int | str | None = None,
        thread_id: int | None = None,
        reply_markup: str | None = None,
    ) -> None:
        """发送消息（纯文本或带按钮）."""
        payload = {
            "chat_id": chat_id or CHAT_ID,
            "text": text,
            "parse_mode": "HTML",
        }
        if reply_markup:
            payload["reply_markup"] = reply_markup
        tid = thread_id or THREAD_ID
        if tid:
            payload["message_thread_id"] = tid
        try:
            url = f"{TG_API_BASE}/sendMessage"
            data = json.dumps(payload).encode()
            req = urllib.request.Request(
                url, data=data,
                headers={"Content-Type": "application/json"},
                method="POST")
            urllib.request.urlopen(req, timeout=10)
        except Exception:
            logger.exception("发送失败")

    def _send_with_buttons(
        self, text: str,
        buttons: list[tuple[str, str]],
        chat_id: int | str | None = None,
        thread_id: int | None = None,
    ) -> None:
        """发送带按钮的消息."""
        keyboard = []
        row = []
        for label, callback_data in buttons:
            row.append({"text": label, "callback_data": callback_data})
            if len(row) >= 3:
                keyboard.append(row)
                row = []
        if row:
            keyboard.append(row)
        self._send(text, chat_id, thread_id,
                   reply_markup=json.dumps({"inline_keyboard": keyboard}))

    def _answer_callback(self, callback_id: str) -> None:
        """告诉 Telegram 我们已处理这个回调."""
        url = f"{TG_API_BASE}/answerCallbackQuery"
        data = json.dumps({"callback_query_id": callback_id}).encode()
        req = urllib.request.Request(url, data=data,
            headers={"Content-Type": "application/json"}, method="POST")
        with contextlib.suppress(Exception):
            urllib.request.urlopen(req, timeout=5)

    # ========== 消息路由 ==========

    def _handle_update(self, update: dict[str, Any]) -> None:
        self._last_update_id = update.get("update_id", 0)

        # 按钮回调
        if "callback_query" in update:
            self._handle_callback(update["callback_query"])
            return

        # 文字命令
        msg = update.get("message", {})
        text = msg.get("text", "").strip()
        chat_id = msg.get("chat", {}).get("id")
        thread_id = msg.get("message_thread_id")

        if not text.startswith("/"):
            return

        parts = text.split(maxsplit=1)
        cmd = parts[0].lower().split("@")[0]  # 去掉 @bot_name
        args = parts[1] if len(parts) > 1 else ""

        reply = None
        if cmd == "/status":
            reply = self._cmd_status(args)
        elif cmd == "/pnl":
            self._cmd_pnl(chat_id, thread_id)
            return
        elif cmd == "/trades":
            self._cmd_trades(chat_id, thread_id)
            return
        elif cmd == "/summary":
            reply = self._cmd_summary()
        elif cmd == "/win":
            reply = self._cmd_win()
        elif cmd == "/help":
            reply = self._cmd_help()

        if reply:
            self._send(reply, chat_id, thread_id)

    def _handle_callback(self, callback: dict[str, Any]) -> None:
        """处理按钮点击."""
        data = callback.get("data", "")
        chat_id = callback.get("message", {}).get("chat", {}).get("id")
        thread_id = callback.get("message", {}).get("message_thread_id")

        callback_id = callback.get("id")
        if not callback_id:
            return
        self._answer_callback(callback_id)

        parts = data.split(":")
        cmd = parts[0]
        arg = parts[1] if len(parts) > 1 else ""

        reply = None

        # === PnL ===
        if cmd == "pnl_menu":
            if arg == "type":
                buttons = [(t, f"pnl:{t}") for t in STRATEGY_TYPES]
                self._send_with_buttons(
                    "📊 选择策略类型：",
                    buttons, chat_id, thread_id,
                )
            elif arg == "interval":
                buttons = [(iv, f"pnl_iv:{iv}") for iv in INTERVALS]
                self._send_with_buttons(
                    "📊 选择时间周期：",
                    buttons, chat_id, thread_id,
                )
        elif cmd == "pnl":
            if arg == "ALL":
                reply = self._cmd_pnl_by_strategy(arg)
            else:
                self._cmd_pnl_layer2(arg, chat_id, thread_id)
        elif cmd == "pnl_iv":
            self._cmd_pnl_layer2_iv(arg, chat_id, thread_id)
        elif cmd == "pnl_id":
            reply = self._cmd_pnl_by_id(arg)
        elif cmd == "pnl_type":
            reply = self._cmd_pnl_by_strategy(arg)
        elif cmd == "pnl_interval":
            reply = self._cmd_pnl_by_interval(arg)

        # === Trades ===
        elif cmd == "trades_menu":
            if arg == "type":
                buttons = [(t, f"trades:{t}") for t in STRATEGY_TYPES]
                self._send_with_buttons(
                    "📋 选择策略类型：",
                    buttons, chat_id, thread_id,
                )
            elif arg == "interval":
                buttons = [(iv, f"trades_iv:{iv}") for iv in INTERVALS]
                self._send_with_buttons(
                    "📋 选择时间周期：",
                    buttons, chat_id, thread_id,
                )
        elif cmd == "trades":
            if arg == "ALL":
                reply = self._cmd_trades_by_strategy(arg)
            else:
                self._cmd_trades_layer2(arg, chat_id, thread_id)
        elif cmd == "trades_iv":
            self._cmd_trades_layer2_iv(arg, chat_id, thread_id)
        elif cmd == "trades_id":
            reply = self._cmd_trades_by_id(arg)
        elif cmd == "trades_type":
            reply = self._cmd_trades_by_strategy(arg)
        elif cmd == "trades_interval":
            reply = self._cmd_trades_by_interval(arg)

        if reply:
            self._send(reply, chat_id, thread_id)

    # ========== 命令实现 ==========

    def _cmd_status(self, args: str) -> str:
        """/status [name] — 策略状态."""
        try:
            with open(STATES_PATH, encoding="utf-8") as f:
                states = json.load(f)
        except Exception:
            return "❌ strategy_states.json 未找到"

        if args:
            # 模糊匹配
            keyword = args.lower()
            states = {k: v for k, v in states.items() if keyword in k.lower()}
            if not states:
                return f"❌ 没有匹配 '{args}' 的策略"

        active = {k: v for k, v in states.items() if v.get("position")}
        idle = {k: v for k, v in states.items() if not v.get("position")}

        lines = [f"📋 <b>策略状态</b> ({len(active)} 持仓 / {len(idle)} 空闲)\n"]

        if active:
            for sid, s in active.items():
                direction = "🟢" if s.get("position") == "BUY" else "🔴"
                entry = s.get("entry_price", 0)
                size = s.get("position_size", 0)
                ttp = s.get("_last_ttp_level", 0)
                ttp_str = f" TTP={ttp:,.2f}" if ttp > 0 else ""
                lines.append(
                    f"{direction} {sid}: "
                    f"${entry:,.2f} x{size:.4f}{ttp_str}",
                )

        if idle and not args:
            lines.append(f"\n⏸ 空闲: {len(idle)} 个策略等待信号")
        elif idle:
            lines.extend(f"⏸ {sid}: 空闲" for sid in idle)

        return "\n".join(lines)

    def _cmd_pnl(self, chat_id: int | str | None, thread_id: int | None) -> None:
        """/pnl — 三入口：策略类型 / 时间周期 / 全部."""
        buttons = [
            ("📋 按策略类型", "pnl_menu:type"),
            ("⏱ 按时间周期", "pnl_menu:interval"),
            ("📊 全部", "pnl:ALL"),
        ]
        self._send_with_buttons("📊 查看 PnL：", buttons, chat_id, thread_id)

    def _cmd_pnl_layer2(
        self, strategy_type: str,
        chat_id: int | str | None,
        thread_id: int | None,
    ) -> None:
        """第二层：列出该类型下所有策略 ID 让用户选."""
        ids = [
            cfg.strategy_id for cfg in TEAM
            if cfg.strategy == strategy_type
        ]
        buttons = [(sid, f"pnl_id:{sid}") for sid in ids]
        buttons.append((
            f"📊 全部 {strategy_type}",
            f"pnl_type:{strategy_type}",
        ))
        self._send_with_buttons(
            f"📊 {strategy_type} 策略：",
            buttons, chat_id, thread_id,
        )

    def _cmd_pnl_layer2_iv(
        self, interval: str,
        chat_id: int | str | None,
        thread_id: int | None,
    ) -> None:
        """按时间周期列出策略 ID."""
        ids = [
            cfg.strategy_id for cfg in TEAM
            if cfg.interval == interval
        ]
        buttons = [(sid, f"pnl_id:{sid}") for sid in ids]
        buttons.append((
            f"📊 全部 {interval}",
            f"pnl_interval:{interval}",
        ))
        self._send_with_buttons(
            f"📊 {interval} 策略：",
            buttons, chat_id, thread_id,
        )

    def _cmd_pnl_by_interval(self, interval: str) -> str:
        """按时间周期查 PnL."""
        conn = self._get_db()
        if not conn:
            return DB_NOT_FOUND
        today = datetime.now(timezone.utc).strftime("%Y-%m-%d")
        rows = conn.execute("""
            SELECT strategy_id, COUNT(*), SUM(pnl), SUM(fee)
            FROM live_trades
            WHERE close_time LIKE ? AND strategy_id LIKE ?
            GROUP BY strategy_id ORDER BY SUM(pnl) DESC
        """, (f"{today}%", f"%_{interval}")).fetchall()
        conn.close()
        if not rows:
            return f"📊 今日 {interval} 无交易"
        total_pnl = sum(r[2] or 0 for r in rows)
        total_fee = sum(r[3] or 0 for r in rows)
        lines = [f"📊 <b>今日 {interval} PnL</b>\n"]
        for r in rows:
            pnl = r[2] or 0
            emoji = pnl_emoji(pnl)
            sign = "+" if pnl >= 0 else ""
            fee_val = r[3] or 0
            lines.append(
                f"{emoji} {r[0]}: {r[1]}笔 "
                f"{sign}{pnl:,.2f} (费{fee_val:,.2f})",
            )
        sign = "+" if total_pnl >= 0 else ""
        lines.append(
            f"\n<b>合计: {sign}{total_pnl:,.2f}"
            f" (手续费 {total_fee:,.2f})</b>",
        )
        return "\n".join(lines)

    def _cmd_pnl_by_id(self, strategy_id: str) -> str:
        """按单个策略 ID 查 PnL."""
        conn = self._get_db()
        if not conn:
            return DB_NOT_FOUND
        today = datetime.now(timezone.utc).strftime("%Y-%m-%d")
        rows = conn.execute("""
            SELECT COUNT(*), SUM(pnl), SUM(fee)
            FROM live_trades
            WHERE close_time LIKE ? AND strategy_id = ?
        """, (f"{today}%", strategy_id)).fetchone()
        conn.close()
        if not rows or not rows[0]:
            return f"📊 {strategy_id} 今日无交易"
        trades, pnl, fee = rows[0], rows[1] or 0, rows[2] or 0
        emoji = pnl_emoji(pnl)
        sign = "+" if pnl >= 0 else ""
        return (
            f"{emoji} <b>{strategy_id}</b>\n"
            f"今日 {trades} 笔 | PnL: "
            f"{sign}{pnl:,.2f} | 手续费: {fee:,.2f}"
        )

    def _cmd_pnl_by_strategy(self, strategy_type: str) -> str:
        """按钮回调：按策略类型查今日 PnL."""
        conn = self._get_db()
        if not conn:
            return DB_NOT_FOUND

        today = datetime.now(timezone.utc).strftime("%Y-%m-%d")

        if strategy_type == "ALL":
            where = "WHERE close_time LIKE ?"
            params: tuple[str, ...] = (f"{today}%",)
        else:
            where = "WHERE close_time LIKE ? AND strategy_id LIKE ?"
            params = (f"{today}%", f"%{strategy_type}%")

        rows = conn.execute(f"""
            SELECT strategy_id, COUNT(*) as trades,
                   SUM(pnl) as total_pnl, SUM(fee) as total_fee
            FROM live_trades
            {where}
            GROUP BY strategy_id
            ORDER BY total_pnl DESC
        """, params).fetchall()
        conn.close()

        if not rows:
            label = strategy_type if strategy_type != "ALL" else "全部"
            return f"📊 今日 {label} 无交易"

        total_pnl = sum(r[2] or 0 for r in rows)
        total_fee = sum(r[3] or 0 for r in rows)
        total_trades = sum(r[1] or 0 for r in rows)

        lines = [f"📊 <b>今日 PnL</b> ({total_trades} 笔)\n"]
        for r in rows:
            pnl = r[2] or 0
            fee = r[3] or 0
            emoji = pnl_emoji(pnl)
            sign = "+" if pnl >= 0 else ""
            lines.append(
                f"{emoji} {r[0]}: {r[1]}笔 "
                f"{sign}{pnl:,.2f} (费{fee:,.2f})",
            )

        sign = "+" if total_pnl >= 0 else ""
        lines.append(
            f"\n<b>合计: {sign}{total_pnl:,.2f}"
            f" USD (手续费 {total_fee:,.2f})</b>",
        )
        return "\n".join(lines)

    def _cmd_trades(self, chat_id: int | str | None, thread_id: int | None) -> None:
        """/trades — 三入口：策略类型 / 时间周期 / 全部."""
        buttons = [
            ("📋 按策略类型", "trades_menu:type"),
            ("⏱ 按时间周期", "trades_menu:interval"),
            ("📋 全部", "trades:ALL"),
        ]
        self._send_with_buttons("📋 查看交易：", buttons, chat_id, thread_id)

    def _cmd_trades_layer2(
        self, strategy_type: str,
        chat_id: int | str | None,
        thread_id: int | None,
    ) -> None:
        """第二层：列出该类型下所有策略 ID."""
        ids = [cfg.strategy_id for cfg in TEAM if cfg.strategy == strategy_type]
        buttons = [(sid, f"trades_id:{sid}") for sid in ids]
        buttons.append((f"📋 全部 {strategy_type}", f"trades_type:{strategy_type}"))
        self._send_with_buttons(
            f"📋 {strategy_type} 策略：",
            buttons, chat_id, thread_id,
        )

    def _cmd_trades_layer2_iv(
        self, interval: str,
        chat_id: int | str | None,
        thread_id: int | None,
    ) -> None:
        """按时间周期列出策略 ID."""
        ids = [cfg.strategy_id for cfg in TEAM if cfg.interval == interval]
        buttons = [(sid, f"trades_id:{sid}") for sid in ids]
        buttons.append((f"📋 全部 {interval}", f"trades_interval:{interval}"))
        self._send_with_buttons(f"📋 {interval} 策略：", buttons, chat_id, thread_id)

    def _cmd_trades_by_interval(self, interval: str) -> str:
        """按时间周期查最近交易."""
        conn = self._get_db()
        if not conn:
            return DB_NOT_FOUND
        rows = conn.execute(f"""
            SELECT {TRADES_SELECT_COLS}
            FROM live_trades WHERE strategy_id LIKE ?
            ORDER BY id DESC LIMIT 10
        """, (f"%_{interval}",)).fetchall()
        conn.close()
        if not rows:
            return f"📋 {interval} 无交易记录"
        lines = [f"📋 <b>{interval} 最近交易</b>\n"]
        for r in rows:
            pnl = r[4] or 0
            emoji = pnl_emoji(pnl)
            ct = (r[7] or "")[:16]
            sign = "+" if pnl >= 0 else ""
            lines.append(
                f"{emoji} {r[0]} {r[1]}"
                f" {sign}{pnl:,.2f} ({r[6]}) {ct}",
            )
        return "\n".join(lines)

    def _cmd_trades_by_id(self, strategy_id: str) -> str:
        """按单个策略 ID 查最近交易."""
        conn = self._get_db()
        if not conn:
            return DB_NOT_FOUND
        rows = conn.execute("""
            SELECT side, entry_price, exit_price, pnl, fee, close_reason, close_time
            FROM live_trades WHERE strategy_id = ?
            ORDER BY id DESC LIMIT 10
        """, (strategy_id,)).fetchall()
        conn.close()
        if not rows:
            return f"📋 {strategy_id} 无交易记录"
        lines = [f"📋 <b>{strategy_id}</b> 最近交易\n"]
        for r in rows:
            pnl = r[3] or 0
            emoji = pnl_emoji(pnl)
            ct = (r[6] or "")[:16]
            sign = "+" if pnl >= 0 else ""
            lines.append(
                f"{emoji} {r[0]}"
                f" ${r[1]:,.2f}→${r[2]:,.2f}"
                f" {sign}{pnl:,.2f} ({r[5]}) {ct}",
            )
        return "\n".join(lines)

    def _cmd_trades_by_strategy(self, strategy_type: str) -> str:
        """按钮回调：按策略类型查最近交易."""
        conn = self._get_db()
        if not conn:
            return DB_NOT_FOUND

        if strategy_type == "ALL":
            rows = conn.execute(f"""
                SELECT {TRADES_SELECT_COLS}
                FROM live_trades ORDER BY id DESC LIMIT 10
            """).fetchall()
        else:
            rows = conn.execute(f"""
                SELECT {TRADES_SELECT_COLS}
                FROM live_trades WHERE strategy_id LIKE ?
                ORDER BY id DESC LIMIT 10
            """, (f"%{strategy_type}%",)).fetchall()
        conn.close()

        if not rows:
            return f"📋 {strategy_type} 无交易记录"

        lines = [f"📋 <b>最近交易</b> ({strategy_type})\n"]
        for r in rows:
            pnl = r[4] or 0
            emoji = pnl_emoji(pnl)
            close_time = (r[7] or "")[:16]
            lines.append(
                f"{emoji} {r[0]} {r[1]} ${r[2]:,.2f}→${r[3]:,.2f} "
                f"{'+'if pnl>=0 else ''}{pnl:,.2f} ({r[6]}) {close_time}",
            )
        return "\n".join(lines)

    def _cmd_summary(self) -> str:
        """/summary — 总体统计."""
        conn = self._get_db()
        if not conn:
            return DB_NOT_FOUND

        row = conn.execute("""
            SELECT COUNT(*), SUM(pnl), SUM(fee),
                   SUM(CASE WHEN pnl > 0 THEN 1 ELSE 0 END),
                   SUM(CASE WHEN pnl < 0 THEN 1 ELSE 0 END)
            FROM live_trades
        """).fetchone()
        conn.close()

        if not row or not row[0]:
            return "📊 暂无交易记录"

        total = row[0]
        pnl, fee = row[1] or 0, row[2] or 0
        wins, losses = row[3] or 0, row[4] or 0
        win_rate = wins / total * 100 if total > 0 else 0

        return (
            "📊 <b>总体统计</b>\n\n"
            f"总交易: {total} 笔\n"
            f"胜率: {win_rate:.1f}% ({wins}胜 {losses}负)\n"
            f"总 PnL: {'+'if pnl>=0 else ''}{pnl:,.2f} USD\n"
            f"总手续费: {fee:,.2f} USD\n"
            f"净利润: {'+'if (pnl-fee)>=0 else ''}{pnl-fee:,.2f} USD"
        )

    def _cmd_win(self) -> str:
        """/win — 策略 PnL 排名."""
        conn = self._get_db()
        if not conn:
            return DB_NOT_FOUND

        rows = conn.execute("""
            SELECT strategy_id, COUNT(*), SUM(pnl), SUM(fee)
            FROM live_trades
            GROUP BY strategy_id
            ORDER BY SUM(pnl) DESC
        """).fetchall()
        conn.close()

        if not rows:
            return "🏆 暂无交易记录"

        lines = ["🏆 <b>策略排名</b>\n"]
        for i, r in enumerate(rows):
            pnl = r[2] or 0
            fee = r[3] or 0
            medal = ["🥇", "🥈", "🥉"][i] if i < 3 else f"{i+1}."
            sign = "+" if pnl >= 0 else ""
            lines.append(
                f"{medal} {r[0]}: {r[1]}笔"
                f" {sign}{pnl:,.2f} (费{fee:,.2f})",
            )

        return "\n".join(lines)

    def _cmd_help(self) -> str:
        """/help — 帮助."""
        return (
            "🤖 <b>Trader Bot 命令</b>\n\n"
            "/status — 全部策略状态\n"
            "/status mean — 模糊匹配\n"
            "/pnl — 今日 PnL（按策略类型）\n"
            "/trades — 最近交易（按策略类型）\n"
            "/summary — 总体统计\n"
            "/win — 策略排名\n"
            "/help — 帮助"
        )

    # ========== 数据库 ==========

    def _get_db(self) -> sqlite3.Connection | None:
        if not os.path.exists(DB_PATH):
            return None
        return sqlite3.connect(DB_PATH)


# ========== 主程序 ==========

def main() -> None:
    from dotenv import load_dotenv
    load_dotenv(os.path.join(ROOT, ".env"))

    # 重新读 .env（load_dotenv 后全局变量已过期），同步重建 TG_API_BASE
    global BOT_TOKEN, CHAT_ID, THREAD_ID, TG_API_BASE
    BOT_TOKEN = os.getenv("TELEGRAM_BOT_TOKEN", "")
    CHAT_ID = os.getenv("TELEGRAM_CHAT_ID", "")
    THREAD_ID = int(os.getenv("TELEGRAM_TRADER_THREAD_ID", "12030"))
    TG_API_BASE = f"https://api.telegram.org/bot{BOT_TOKEN}"

    logging.basicConfig(
        level=logging.INFO,
        format="%(asctime)s [%(name)s] %(levelname)s %(message)s",
    )

    if not BOT_TOKEN:
        print("❌ TELEGRAM_BOT_TOKEN 未配置")
        sys.exit(1)

    bot = TraderBot()
    bot.run()


if __name__ == "__main__":
    main()
