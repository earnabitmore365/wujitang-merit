# ==================== API ====================

def _auth_headers(verb, path, body_str=''):
    if not API_SECRET:
        raise RuntimeError("API 密钥未配置，请先调用 load_env()")
    expires = int(time.time()) + 30
    message = verb + path + str(expires) + body_str
    signature = hmac.new(
        API_SECRET.encode(), message.encode(), hashlib.sha256
    ).hexdigest()
    return {
        'api-key': API_KEY,
        'api-expires': str(expires),
        'api-signature': signature,
        'Content-Type': 'application/json',
    }


def _api_get(path, query=None):
    url = API_BASE_URL + path
    if query:
        qs = urllib.parse.urlencode(query)
        path = f"{path}?{qs}"
        url = f"{url}?{qs}"
    headers = _auth_headers('GET', path)
    req = urllib.request.Request(url, headers=headers, method='GET')
    try:
        with urllib.request.urlopen(req, timeout=10) as resp:
            return json.loads(resp.read().decode())
    except Exception as e:
        return {'error': str(e)}


def fetch_balance():
    result = _api_get(f'{API_PATH}/user/margin', {'currency': 'USDt'})
    if isinstance(result, dict) and 'error' not in result:
        d = 1e6
        return {
            'wallet': float(result.get('walletBalance', 0)) / d,
            'available': float(result.get('availableMargin', 0)) / d,
            'unrealized': float(result.get('unrealisedPnl', 0)) / d,
            'margin_used': float(result.get('maintMargin', 0)) / d,
        }
    return None


def fetch_positions():
    result = _api_get(f'{API_PATH}/position',
                      {'filter': json.dumps({'isOpen': True})})
    if not isinstance(result, list):
        return []
    positions = []
    for r in result:
        qty = r.get('currentQty', 0)
        if qty == 0:
            continue
        positions.append({
            'symbol': r.get('symbol', ''),
            'side': 'LONG' if qty > 0 else 'SHORT',
            'qty': abs(qty),
            'entry': float(r.get('avgEntryPrice', 0) or 0),
            'mark': float(r.get('markPrice', 0) or 0),
            'upnl': float(r.get('unrealisedPnl', 0) or 0) / 1e6,
            'leverage': r.get('leverage', 0),
            'liq_price': float(r.get('liquidationPrice', 0) or 0),
        })
    return positions


# ==================== 日志解析 ====================

def _read_tail(path, n=500):
    """读日志尾部 n 行"""
    if not os.path.exists(path):
        return []
    try:
        with open(path, 'rb') as f:
            # 从文件尾部往回找
            f.seek(0, 2)
            size = f.tell()
            buf_size = min(size, n * 500)  # 估算每行 500 字节（含 JSON 格式日志）
            f.seek(max(0, size - buf_size))
            data = f.read().decode('utf-8', errors='replace')
        lines = data.strip().split('\n')
        return lines[-n:]
    except Exception:
        return []


def parse_regime_status(log_path):
    """从 ETH 日志提取最新 regime 状态"""
    lines = _read_tail(log_path, 300)
    status = {
        'regime': '?', 'mode': '?', 'signal': '?',
        'fused': '?', 'switches': '?', 'last_time': '?',
    }

    # 从后往前找最新的 regime 行
    for line in reversed(lines):
        if 'regime=' in line and 'mode=' in line:
            # 格式: regime=盘整 mode=normal signal=HOLD fused=False switches=0
            parts = line.split()
            for p in parts:
                if p.startswith('regime='):
                    status['regime'] = p.split('=', 1)[1]
                elif p.startswith('mode='):
                    status['mode'] = p.split('=', 1)[1]
                elif p.startswith('signal='):
                    val = p.split('=', 1)[1]
                    # 清理 Signal.HOLD → HOLD
                    if val.startswith('Signal.'):
                        val = val[7:]
                    status['signal'] = val
                elif p.startswith('fused='):
                    status['fused'] = p.split('=', 1)[1]
                elif p.startswith('switches='):
                    status['switches'] = p.split('=', 1)[1]
            # 提取时间戳（行首 2026-03-18 19:38:xx）
            if len(line) > 19 and line[4] == '-':
                status['last_time'] = line[:19]
            break

    return status


def parse_signal_status(log_path):
    """从 XRP 日志提取最新信号"""
    lines = _read_tail(log_path, 300)
    status = {'signal': '?', 'action': '?', 'position': '?', 'balance': '?', 'last_time': '?'}

    for line in reversed(lines):
        if '信号=' in line:
            parts = line.split()
            for p in parts:
                if p.startswith('信号='):
                    status['signal'] = p.split('=', 1)[1]
                elif p.startswith('操作='):
                    status['action'] = p.split('=', 1)[1]
                elif p.startswith('持仓='):
                    status['position'] = p.split('=', 1)[1]
                elif p.startswith('余额='):
                    status['balance'] = p.split('=', 1)[1]
            if len(line) > 19 and line[4] == '-':
                status['last_time'] = line[:19]
            break

    return status


def parse_regime_switches(log_path, max_entries=5):
    """提取 regime 切换历史"""
    lines = _read_tail(log_path, 1000)
    switches = []

    for line in lines:
        if '[切换]' in line:
            ts = line[:19] if len(line) > 19 and line[4] == '-' else '?'
            # 提取 [切换] 后的内容
            idx = line.find('[切换]')
            detail = line[idx:].strip() if idx >= 0 else line.strip()
            switches.append(f"{ts}  {detail}")

    return switches[-max_entries:]


def parse_recent_trades(log_path, max_entries=3):
    """提取最近交易"""
    lines = _read_tail(log_path, 500)
    trades = []

    for line in lines:
        if '开仓' in line or '平仓' in line or '反手' in line:
            ts = line[:19] if len(line) > 19 and line[4] == '-' else '?'
            # 找到关键词位置
            for kw in ['开仓', '平仓', '反手']:
                idx = line.find(kw)
                if idx >= 0:
                    detail = line[idx:].strip()[:80]
                    trades.append(f"{ts}  {detail}")
                    break

    return trades[-max_entries:]


def parse_errors(log_path, max_entries=3):
    """提取最近错误"""
    lines = _read_tail(log_path, 500)
    errors = []

    for line in lines:
        if 'ERROR' in line or '异常' in line:
            ts = line[:19] if len(line) > 19 and line[4] == '-' else '?'
            errors.append(f"{ts}  {line[20:100].strip()}")

    return errors[-max_entries:]


def check_process_alive():
    """检查 bitmex_race.py 进程是否在跑"""
    try:
        import subprocess
        result = subprocess.run(
            ['pgrep', '-af', 'bitmex_race.py'],
            capture_output=True, text=True, timeout=5
        )
        procs = [l for l in result.stdout.strip().split('\n') if l and 'pgrep' not in l]
        return procs
    except Exception:
        return []


def get_log_freshness(log_path):
    """日志最后修改距今多少秒"""
    if not os.path.exists(log_path):
        return -1
    try:
        mtime = os.path.getmtime(log_path)
        return int(time.time() - mtime)
    except Exception:
        return -1


# ==================== 渲染 ====================

def render():
    now = datetime.now().strftime('%Y-%m-%d %H:%M:%S')

    lines = []
    w = 72
    lines.append(f"{C_BOLD}{'=' * w}{C_RESET}")
    lines.append(f"{C_BOLD}  Auto-Trading 实盘监控  |  {now}{C_RESET}")
    lines.append(f"{C_BOLD}{'=' * w}{C_RESET}")

    # --- 进程状态 ---
    procs = check_process_alive()
    lines.append('')
    if procs:
        lines.append(f"  {C_GREEN}● 进程运行中{C_RESET}（{len(procs)} 个 bitmex_race.py）")
    else:
        lines.append(f"  {C_RED}● 进程未检测到!{C_RESET}")

    # --- 余额 ---
    balance = fetch_balance()
    lines.append('')
    if balance:
        upnl = balance['unrealized']
        upnl_c = C_GREEN if upnl >= 0 else C_RED
        upnl_s = f"+{upnl:.4f}" if upnl >= 0 else f"{upnl:.4f}"
        lines.append(f"  余额: {C_BOLD}${balance['wallet']:.2f}{C_RESET} USDT"
                     f"    可用: ${balance['available']:.2f}"
                     f"    保证金: ${balance['margin_used']:.2f}"
                     f"    浮盈: {upnl_c}${upnl_s}{C_RESET}")
    else:
        lines.append(f"  余额: {C_RED}API 查询失败{C_RESET}")

    # --- 持仓 ---
    positions = fetch_positions()
    if positions:
        lines.append('')
        lines.append(f"  {C_BOLD}持仓:{C_RESET}")
        for p in positions:
            side_c = C_GREEN if p['side'] == 'LONG' else C_RED
            pnl_c = C_GREEN if p['upnl'] >= 0 else C_RED
            pnl_s = f"+{p['upnl']:.4f}" if p['upnl'] >= 0 else f"{p['upnl']:.4f}"
            lines.append(
                f"    {p['symbol']:12s} {side_c}{p['side']:5s}{C_RESET}"
                f" {p['qty']}合约 @ ${p['entry']:.4f}"
                f"  PnL: {pnl_c}${pnl_s}{C_RESET}"
                f"  强平: ${p['liq_price']:.2f}"
            )
    else:
        lines.append(f"  持仓: {C_DIM}无{C_RESET}")

    # --- 策略状态 ---
    lines.append('')
    lines.append(f"  {C_BOLD}{'-' * (w - 4)}{C_RESET}")

    for s in STRATEGIES:
        lines.append('')
        freshness = get_log_freshness(s['log'])
        if freshness < 0:
            fresh_str = f"{C_RED}日志不存在{C_RESET}"
        elif freshness < 120:
            fresh_str = f"{C_GREEN}活跃（{freshness}秒前）{C_RESET}"
        elif freshness < 600:
            fresh_str = f"{C_YELLOW}{freshness}秒前{C_RESET}"
        else:
            fresh_str = f"{C_RED}{freshness // 60}分钟前{C_RESET}"

        lines.append(f"  {C_CYAN}{C_BOLD}[{s['name']}]{C_RESET}"
                     f"  {s['coin']}/{s['interval']}  ${s['margin']}"
                     f"  日志: {fresh_str}")

        if s['has_regime']:
            # ETH: 完整 regime 状态
            rs = parse_regime_status(s['log'])
            mode_c = C_MAGENTA if rs['mode'] == 'flipped' else C_GREEN
            fused_str = f"{C_RED}[熔断]{C_RESET}" if rs['fused'] == 'True' else ''
            lines.append(
                f"    regime={C_BOLD}{rs['regime']}{C_RESET}"
                f"  mode={mode_c}{rs['mode']}{C_RESET}"
                f"  signal={C_BOLD}{rs['signal']}{C_RESET}"
                f"  switches={rs['switches']}"
                f"  {fused_str}"
            )
            lines.append(f"    最后更新: {C_DIM}{rs['last_time']}{C_RESET}")
        else:
            # XRP: 简单信号
            ss = parse_signal_status(s['log'])
            lines.append(
                f"    signal={C_BOLD}{ss['signal']}{C_RESET}"
                f"  操作={ss['action']}"
                f"  持仓={ss['position']}"
                f"  余额={ss['balance']}"
            )
            lines.append(f"    最后更新: {C_DIM}{ss['last_time']}{C_RESET}")

        # 最近交易
        trades = parse_recent_trades(s['log'], 2)
        if trades:
            lines.append(f"    {C_DIM}最近交易:{C_RESET}")
            for t in trades:
                lines.append(f"      {t}")

        # 错误
        errors = parse_errors(s['log'], 2)
        if errors:
            lines.append(f"    {C_RED}最近错误:{C_RESET}")
            for e in errors:
                lines.append(f"      {C_RED}{e}{C_RESET}")

    # --- Regime 切换历史 ---
    eth_log = STRATEGIES[0]['log']
    switches = parse_regime_switches(eth_log, 5)
    if switches:
        lines.append('')
        lines.append(f"  {C_BOLD}{'-' * (w - 4)}{C_RESET}")
        lines.append(f"  {C_BOLD}Regime 切换历史（最近 5 次）{C_RESET}")
        for sw in switches:
            lines.append(f"    {sw}")

    # --- 底部 ---
    lines.append('')
    lines.append(f"{C_BOLD}{'=' * w}{C_RESET}")

    return '\n'.join(lines)


# ==================== 主入口 ====================

def load_env():
    global API_KEY, API_SECRET
    env_path = os.path.join(ROOT, '.env')
    if not os.path.exists(env_path):
        print(f"错误: 未找到 .env: {env_path}")
        sys.exit(1)

    with open(env_path) as f:
        for line in f:
            line = line.strip()
            if line.startswith('#') or '=' not in line:
                continue
            key, val = line.split('=', 1)
            key = key.strip()
            val = val.strip().strip("'\"")
            if key == 'BITMEX_API_KEY':
                API_KEY = val
            elif key == 'BITMEX_API_SECRET':
                API_SECRET = val

    if not API_KEY or not API_SECRET:
        print("错误: .env 中缺少 BITMEX_API_KEY 或 BITMEX_API_SECRET")
        sys.exit(1)


def main():
    load_env()
    print(render())


if __name__ == '__main__':
    main()
