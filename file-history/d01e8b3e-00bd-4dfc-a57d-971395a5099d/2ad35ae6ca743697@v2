    # 账户管理
    # ═══════════════════════════════════════════════

    def get_balance(self, currency: str = "USDt") -> dict[str, Any]:
        """获取账户余额.

        Args:
            currency: 钱包币种（'USDt' = USDT保证金，'XBt' = BTC保证金）

        Returns:
            dict: {
                'usdc': 总余额（美元）,
                'available': 可用余额,
                'margin_used': 已用保证金,
                'unrealized_pnl': 未实现盈亏,
            }

        """
        result = cast(dict[str, Any], self._get(f"{API_BASE}/user/margin", query={"currency": currency}))

        if "error" in result:
            return {"usdc": 0, "available": 0}

        # USDt 单位是 1e6（微美元），XBt 单位是 1e8（聪）
        divisor = 1e6 if currency == "USDt" else 1e8

        wallet = float(result.get("walletBalance", 0)) / divisor
        available = float(result.get("availableMargin", 0)) / divisor
        margin_used = float(result.get("maintMargin", 0)) / divisor
        unrealized = float(result.get("unrealisedPnl", 0)) / divisor

        return {
            "usdc": wallet,
            "available": available,
            "margin_used": margin_used,
            "unrealized_pnl": unrealized,
        }

    def get_trade_fee(self, order_id: str) -> float:
        """查询指定订单的手续费.

        Args:
            order_id: 订单 ID（平仓单的 orderID）

        Returns:
            float: 手续费（美元，正数=付费，负数=返佣）

        """
        if not order_id:
            return 0.0

        result = self._get(f"{API_BASE}/execution/tradeHistory", query={
            "filter": json.dumps({"orderID": order_id}),
        })

        if not isinstance(result, list) or not result:
            return 0.0

        total_fee = 0.0
        for exec_row in result:
            comm = float(exec_row.get("execComm", 0) or 0)
            total_fee += comm / 1e6  # 微美元→美元
        return total_fee

    # ═══════════════════════════════════════════════
    # 杠杆管理
    # ═══════════════════════════════════════════════

    def set_leverage(self, coin: str, leverage: float) -> bool:
        """设置杠杆.

        Args:
            coin: 币种
            leverage: 杠杆倍数（0 = 全仓模式）

        注意：Hedge Mode 下此 API 不可用，杠杆需在 BitMEX 网页设置。
        adapter 会自动检测并跳过。

        """
        symbol = self._to_symbol(coin)

        # Hedge Mode 检测：查仓位看 strategy 是否为 Long/Short
        if not hasattr(self, "_hedge_mode"):
            self._hedge_mode = None  # 未检测
        if self._hedge_mode is None:
            try:
                pos = self._get(f"{API_BASE}/position", query={"count": "1"})
                if isinstance(pos, list) and pos:
                    strat = pos[0].get("strategy", "OneWay")
                    self._hedge_mode = strat in ("Long", "Short")
                else:
                    self._hedge_mode = False
            except Exception:
                self._hedge_mode = False

        if self._hedge_mode:
            # Hedge Mode 下 API 不可用，杠杆已在网页设置，直接跳过
            self._leverage_set.add(symbol)
            return True

        result = cast(dict[str, Any], self._post(f"{API_BASE}/position/leverage", data={
            "symbol": symbol,
            "leverage": leverage,
        }))
        if "error" in result:
            msg = result["error"].get("message", str(result["error"]))
            if "multi-way" in msg.lower() or "hedge" in msg.lower():
                self._hedge_mode = True
                self._leverage_set.add(symbol)
                return True
            logger.error("设置杠杆失败: %s", result["error"])
            return False
        self._leverage_set.add(symbol)
        return True

    def _ensure_leverage(self, symbol: str) -> None:
        """确保杠杆已设置（每个品种只设一次）."""
        if symbol not in self._leverage_set:
            coin = self._from_symbol(symbol)
            self.set_leverage(coin, self.default_leverage)

    # ═══════════════════════════════════════════════
    # 条件单（止损/止盈）
    # ═══════════════════════════════════════════════

    def place_stop_loss(self, coin: str, stop_price: float,
                        size: float, side: OrderSide) -> OrderResult:
        """止损单（触发后市价执行）.

        Args:
            coin: 币种
            stop_price: 触发价
            size: 数量（币数量，自动转合约）
            side: 方向（平多仓用 SELL，平空仓用 BUY）

        """
        symbol = self._to_symbol(coin)
        contracts = self.coin_to_contracts(coin, size)
        if contracts <= 0:
            return OrderResult(success=False, message=f"止损量太小: {size}")

        data = {
            "symbol": symbol,
            "side": "Buy" if side == OrderSide.BUY else "Sell",
            "orderQty": contracts,
            "stopPx": stop_price,
            "ordType": "Stop",
            "execInst": "Close,LastPrice",  # Hedge Mode 用 Close 不用 ReduceOnly
            # Hedge Mode 必填
            "strategy": ("Long" if side == OrderSide.SELL
                         else "Short"),
        }
        result = cast(dict[str, Any], self._post(f"{API_BASE}/order", data=data))

        if "error" in result:
            msg = result["error"].get("message", str(result["error"]))
            return OrderResult(success=False, message=f"止损单失败: {msg}")

        return OrderResult(
            success=True,
            order_id=result.get("orderID", ""),
            message="止损单已挂",
        )

    def place_take_profit(self, coin: str, tp_price: float,
                          size: float, side: OrderSide) -> OrderResult:
        """止盈单（触发后限价执行）.

        Args:
            coin: 币种
            tp_price: 触发价
            size: 数量（币数量，自动转合约）
            side: 方向

        """
        symbol = self._to_symbol(coin)
        contracts = self.coin_to_contracts(coin, size)
        if contracts <= 0:
            return OrderResult(success=False, message=f"止盈量太小: {size}")

        data = {
            "symbol": symbol,
            "side": "Buy" if side == OrderSide.BUY else "Sell",
            "orderQty": contracts,
            "price": tp_price,
            "stopPx": tp_price,
            "ordType": "LimitIfTouched",
            "execInst": "Close,LastPrice",  # Hedge Mode 用 Close
            # Hedge Mode 必填
            "strategy": ("Long" if side == OrderSide.SELL
                         else "Short"),
        }
        result = cast(dict[str, Any], self._post(f"{API_BASE}/order", data=data))

        if "error" in result:
            msg = result["error"].get("message", str(result["error"]))
            return OrderResult(success=False, message=f"止盈单失败: {msg}")

        return OrderResult(
            success=True,
            order_id=result.get("orderID", ""),
            message="止盈单已挂",
        )

    # ═══════════════════════════════════════════════
    # 工具方法
    # ═══════════════════════════════════════════════

    def _from_symbol(self, symbol: str) -> str:
        """BitMEX 合约代码转币种名."""
        for coin, sym in SYMBOL_MAP.items():
            if sym == symbol:
                return coin
        # fallback: 去掉 USD 后缀
        return symbol.replace("USD", "").replace("USDT", "")

    def _get_u2p(self, coin: str) -> int:
        """获取 underlyingToPositionMultiplier（币 → 合约数量的乘数）.

        缓存结果，每个品种只查一次。
        例：XRP u2p=100 → 1 XRP = 100 合约
        """
        if not hasattr(self, "_u2p_cache"):
            self._u2p_cache: dict[str, int] = {}

        if coin not in self._u2p_cache:
            info = self.get_instrument_info(coin)
            u2p = info.get("underlyingToPositionMultiplier", 1)
            self._u2p_cache[coin] = int(u2p or 1)

        return self._u2p_cache[coin]

    def _get_lot_size(self, coin: str) -> int:
        """获取最小下单量（合约数）."""
        if not hasattr(self, "_lot_cache"):
            self._lot_cache: dict[str, int] = {}

        if coin not in self._lot_cache:
            info = self.get_instrument_info(coin)
            self._lot_cache[coin] = int(info.get("lotSize", 1) or 1)

        return self._lot_cache[coin]

    def coin_to_contracts(self, coin: str, coin_qty: float) -> int:
        """币数量 → 合约数量（向下取整到 lotSize）.

        Args:
            coin: 币种
            coin_qty: 币数量（如 706.5 XRP）

        Returns:
            int: 合约数量（如 70600）

        """
        u2p = self._get_u2p(coin)
        lot = self._get_lot_size(coin)
        contracts = int(coin_qty * u2p)
        # 向下取整到 lotSize 的整数倍
        return (contracts // lot) * lot

    def get_tick_size(self, coin: str) -> float:
        """获取最小价格变动（带缓存）."""
        if not hasattr(self, "_tick_cache"):
            self._tick_cache: dict[str, float] = {}
        if coin not in self._tick_cache:
            info = self.get_instrument_info(coin)
            self._tick_cache[coin] = float(info.get("tickSize", 0.01) or 0.01)
        return self._tick_cache[coin]

    def get_instrument_info(self, coin: str) -> dict[str, Any]:
        """获取合约信息（tick size、lot size 等）."""
        symbol = self._to_symbol(coin)
        result = self._get(f"{API_BASE}/instrument", query={
            "symbol": symbol,
        })
        if isinstance(result, list) and result:
            return cast(dict[str, Any], result[0])
        return {}
