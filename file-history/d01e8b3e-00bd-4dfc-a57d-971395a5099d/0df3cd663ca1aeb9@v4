#!/usr/bin/env python3
"""unified_trader.py — 21 策略并行交易主脚本.

单进程跑 21 个策略。

架构：
  Feed Gateway (ZMQ PUB) → FeedClient → KlineDispatcher → StrategyRunner × 21

启动命令：
  nohup python3 unified_trader.py >> logs/unified.log 2>&1 &

@see trading/team_config.py — TEAM / get_bet_amount / get_needed_intervals
@see trading/kline_dispatcher.py — KlineDispatcher
@see trading/strategy_runner.py — StrategyRunner
@see trading/limit_executor.py — LimitOrderExecutor
@see trading/trade_logger.py — TradeLogger
@see src/data/feed_client.py — FeedClient
@see src/exchange/bitmex/adapter.py — BitMEXAdapter
"""

from __future__ import annotations

import json
import logging
import os
import signal
import sys
import time
from datetime import datetime, timezone
from typing import TYPE_CHECKING, Any

if TYPE_CHECKING:
    from collections.abc import Sequence
    from types import FrameType

_p = os.path.dirname(os.path.abspath(__file__))
while _p != os.path.dirname(_p) and not os.path.exists(os.path.join(_p, '.wuji-root')):
    _p = os.path.dirname(_p)
if _p not in sys.path:
    sys.path.insert(0, _p)
