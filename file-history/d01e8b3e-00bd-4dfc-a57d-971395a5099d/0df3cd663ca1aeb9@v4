if SRC_DIR not in sys.path:
    sys.path.insert(0, SRC_DIR)

import contextlib  # noqa: E402

from data.feed_client import FeedClient  # noqa: E402
from exchange.base import OrderRequest, OrderSide, OrderType  # noqa: E402
from exchange.bitmex.adapter import BitMEXAdapter  # noqa: E402
from kline_dispatcher import KlineDispatcher  # noqa: E402
from limit_executor import LimitOrderExecutor  # noqa: E402
from strategy_runner import StrategyRunner  # noqa: E402
from team_config import (  # noqa: E402
    CIRCUIT_BREAKER_USD,
    LEVERAGE,
    TEAM,
    WITHDRAW_AMOUNT,
    WITHDRAW_THRESHOLD,
    get_active_team,
