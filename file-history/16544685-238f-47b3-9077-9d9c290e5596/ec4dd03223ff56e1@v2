class BacktestEngine:
    """回测引擎."""

    def __init__(
        self,
        coin: str,
        interval: str = "1h",
        days: int = 1095,
        initial_capital: float = 500,
        enable_ttp: bool = True,
        ttp_highlow: bool = True,
        stop_loss_pct: float = 0.1,
        leverage: float = 10.0,
        enable_withdraw: bool = False,  # 默认关闭自动提款功能
        # True=固定注码（策略评估用）
        # False=复利注码（实际收益估算）
        fixed_bet: bool = False,
        candles: list[dict[str, Any]] | None = None,  # 外部传入K线数据
        fixed_bet_amount: float | None = None,  # 默认=初始本金×10%
        fee_rate: float = 0.0,  # taker手续费率（每侧）
        slippage_pct: float = 0.0,  # 滑点百分比（每侧）
        funding_rate_8h: float = 0.0,  # 资金费率（每8小时）
        # "linear"(USDT本位) | "inverse"(币本位)  # noqa: ERA001
        margin_mode: str = "linear",
    ) -> None:
        self.coin = coin.upper()
        self.interval = interval
        self.days = days
        self.initial_capital = initial_capital
        self.enable_ttp = enable_ttp
        self.ttp_highlow = ttp_highlow
        self.stop_loss_pct = stop_loss_pct
        self.leverage = leverage
        self.enable_withdraw = enable_withdraw  # 提款开关
        self.fixed_bet = fixed_bet
        self.fixed_bet_amount = (
            fixed_bet_amount
            if fixed_bet_amount is not None
            else self.initial_capital * 0.1
        )
        self.fee_rate = fee_rate
        self.slippage_pct = slippage_pct
        self.funding_rate_8h = funding_rate_8h
        self.margin_mode = margin_mode  # linear(USDT) | inverse(币本位)

        # TTP 管理器
        ttp_config = TTPConfig(
            ttp_enabled=enable_ttp,
            ttp_buffer_pips=5.0,
            ttp_trigger_pct=0.01,  # 1% 浮盈后启动
        )
        self.ttp_manager = TTPManager(ttp_config)

        # 每日K线数量映射
        self._bars_per_day = {
            "1m": 1440,
            "5m": 288,
            "15m": 96,
            "30m": 48,
            "1h": 24,
            "2h": 12,
            "4h": 6,
            "6h": 4,
            "12h": 2,
            "1d": 1,
        }
        self.bars_per_day = self._bars_per_day.get(interval, 24)

        # 资金费结算间隔（K线数）
        _bar_minutes = {
            "1m": 1, "5m": 5, "15m": 15, "30m": 30,
            "1h": 60, "2h": 120, "4h": 240, "1d": 1440,
        }
        self._bar_minutes = _bar_minutes.get(interval, 60)
        self._bars_per_funding = (
            int((8 * 60) / self._bar_minutes)
            if self._bar_minutes > 0
            else 999999
        )

        # 持仓跟踪（用于计算持仓时长和成本）
        self._position_open_bar = -1

        if candles is not None:
            # 使用外部传入的K线，按天数截取
            if self.days and len(candles) > self.days * self.bars_per_day:
                self.candles = candles[-self.days * self.bars_per_day:]
            else:
                self.candles = candles
        else:
            self.candles = self._load_data()

        if not self.candles:
            logger.error("无法获取 %s K线数据", coin)
            self.candles = []

        self.trades: list[Trade] = []
        # 每笔交易对应的K线索引
        self.trade_candle_indices: list[int] = []
        self.balance: list[float] = [initial_capital]
        # 当前余额（实时更新）
        self.current_balance: float = initial_capital

        # 提款相关变量
        self.withdraw_count = 0  # 提款次数
        self.first_withdraw_day: int | None = None  # 第一次提款时的天数

        bet_mode = "固定" if fixed_bet else "复利"
        wd_status = "开启" if enable_withdraw else "关闭"
        logger.info(
            "回测初始化: %s %s (%d天) | K线: %d"
            " | 注码: %s | 提款: %s",
            coin, interval, days, len(self.candles),
            bet_mode, wd_status,
        )

    def _get_trade_capital(self) -> float:
        """计算本次开仓资金.

        固定注码: 使用 fixed_bet_amount（默认=初始本金×10%）
        复利注码: 用当前余额的10%（模拟实际交易）
        """
        if self.fixed_bet:
            return self.fixed_bet_amount
        return max(self.balance[-1] * 0.1, 100)

    def _calc_raw_pnl(self, entry_p: float, exit_p: float,
                      position_size: float, direction: str) -> float:
        """统一 PnL 计算（linear/inverse 分支）.

        linear:  PnL(USD) = diff / entry × position_size
        inverse: PnL(BNB) = position_size × diff / exit
                 推导: position_size(BNB) × entry = 名义USD
                       名义USD × diff / (entry × exit)
                       = position_size × diff / exit
                       （entry 约掉，跟 Binance 官方一致）
        """
        diff = exit_p - entry_p if direction == "long" else entry_p - exit_p

        if self.margin_mode == "linear":
            return diff / entry_p * position_size
        # inverse
        return position_size * diff / exit_p

    def _calc_trading_costs(
        self, position_size: float, holding_bars: int,
        entry_p: float | None = None, exit_p: float | None = None,
    ) -> tuple[float, float, float]:
        """计算交易成本（手续费+滑点+资金费）.

        linear: 基于 position_size（USD 名义）
        inverse: 基于 USD 名义
                 = position_size(BNB) × entry_p，结算回 BNB
        """
        if self.margin_mode == "linear":
            fee = position_size * self.fee_rate * 2
            slippage = position_size * self.slippage_pct * 2
            funding_count = (
                int(holding_bars / self._bars_per_funding)
                if self._bars_per_funding > 0
                else 0
            )
            funding = position_size * self.funding_rate_8h * funding_count
        else:  # inverse
            assert entry_p is not None and exit_p is not None
            notional_usd = position_size * entry_p
            fee_usd = notional_usd * self.fee_rate * 2
            slip_usd = notional_usd * self.slippage_pct * 2
            funding_count = (
                int(holding_bars / self._bars_per_funding)
                if self._bars_per_funding > 0
                else 0
            )
            fund_usd = notional_usd * self.funding_rate_8h * funding_count
            fee = fee_usd / exit_p
            slippage = slip_usd / exit_p
            funding = fund_usd / exit_p
        return fee, slippage, funding

    def _load_data(self) -> list[dict[str, Any]]:
        """加载K线数据."""
        data_file = os.path.join(
            DATA_DIR, "historical", self.coin,
            f"{self.interval}.json",
        )

        if not os.path.exists(data_file):
            logger.warning("数据文件不存在: %s", data_file)
            return []

        try:
            with open(data_file, encoding="utf-8") as f:
                data: list[Any] = json.load(f)
        except Exception:
            logger.exception("加载数据失败")
            return []
        else:
            # 筛选指定天数的数据
            if self.days and len(data) > self.days * self.bars_per_day:
                data = data[-self.days * self.bars_per_day:]

            logger.info(
                "📁 加载数据: %d 条 | 文件: %s",
                len(data), data_file,
            )
            return data

    def _check_withdraw(self, day_index: int | None = None) -> float:
        """检查是否需要提款.

        Args:
            day_index: 当前是第几天

        Returns:
            提款金额（0表示不需要提款）

        """
        # 如果关闭了提款功能，直接返回0
        if not getattr(self, "enable_withdraw", False):
            return 0

        withdraw_threshold = 5000
        withdraw_amount = 3000

        if self.balance[-1] > withdraw_threshold:
            # 更新提款统计
            self.withdraw_count += 1
            if self.first_withdraw_day is None and day_index is not None:
                self.first_withdraw_day = day_index

            return withdraw_amount
        return 0

    def generate_signals(self, strategy_name: str) -> list[str]:
        """只产信号不执行交易。返回每根K线的信号列表。

        信号产生只看 K 线数据，不看持仓状态。
        4个种子共享同一套信号序列，执行器各自模拟。

        Returns:
            list[str]: 每根K线一个信号 ('BUY'/'SELL'/'HOLD')。
            长度 = len(self.candles)，前 start_idx 根填 'HOLD'。
        """
        if not self.candles:
            logger.error("没有K线数据，无法产信号")
            return []

        strategy = get_strategy(strategy_name)
        if not strategy:
            logger.error("策略不存在: %s", strategy_name)
            return []

        # 初始化 indicator_cache（同 run_backtest）
        init_cache(self.coin, self.interval, self.candles)
        strategy.interval = self.interval
        strategy.current_idx = 0

        if hasattr(strategy, "REQUIRES") and strategy.REQUIRES:
            validate_requires(strategy_name, strategy.REQUIRES)

        n_candles = len(self.candles)
        start_idx = (
            0 if not self.days
            else max(0, n_candles - self.days * self.bars_per_day)
        )
        max_window = 200

        signals: list[str] = ["HOLD"] * n_candles

        for i in range(start_idx, n_candles):
            strategy.current_idx = i
            try:
                if hasattr(strategy, "generate_signal"):
                    window_start = max(0, i + 1 - max_window)
                    klines = self.candles[window_start:i + 1]
                    signal = strategy.generate_signal(self.coin, klines)
                    if hasattr(signal, "signal"):
                        action = signal.signal.value
                    elif hasattr(signal, "value"):
                        action = signal.value
                    else:
                        action = str(signal)
                else:
                    signal = strategy.get_signal(i)
                    action = signal.value if hasattr(signal, "value") else str(signal)
            except Exception:
                logger.exception("信号生成错误 K线 %d", i)
                action = "HOLD"

            signals[i] = action

        return signals

    def run_backtest(
        self, strategy_name: str, strategy: Strategy | None = None,
    ) -> BacktestResult | None:
        """运行回测."""
        if not self.candles:
            logger.error("没有K线数据，无法运行回测")
            return None

        # 创建策略（支持传入预配置的 strategy 对象）
        if strategy is None:
            strategy = get_strategy(strategy_name)
            if not strategy:
                logger.error("策略不存在: %s", strategy_name)
                return None

        logger.info("📊 回测策略: %s", strategy_name)

        # 初始化 indicator_cache
        # （同一 coin+interval 多策略共用，不会重复初始化）
        init_cache(self.coin, self.interval, self.candles)

        # 传递上下文给策略
        # （indicator_cache 需要 interval 和 current_idx）
        strategy.interval = self.interval
        strategy.current_idx = 0

        # 校验策略的 REQUIRES 声明
        if hasattr(strategy, "REQUIRES") and strategy.REQUIRES:
            validate_requires(strategy_name, strategy.REQUIRES)

        closes = [c["close"] for c in self.candles]
        highs = [c["high"] for c in self.candles]
        lows = [c["low"] for c in self.candles]
        # 支持 'timestamp' 和 'time' 两种格式
        times = [
            datetime.fromtimestamp(
                c.get("timestamp", c.get("time", 0)) / 1000, tz=timezone.utc,
            ).strftime("%Y-%m-%d %H:%M")
            for c in self.candles
        ]

        position = "NO_POSITION"  # 当前持仓方向
        entry_price = 0  # 开仓价格

        # 信号计数
        buy_signals = 0
        sell_signals = 0

        n_candles = len(self.candles)
        start_idx = (
            0 if not self.days
            else max(0, n_candles - self.days * self.bars_per_day)
        )

        # 策略最多只需要最近 max_window 根 K 线，避免 O(n²) 的列表拷贝
        max_window = 200

        for i in range(start_idx, n_candles):
            # 更新策略的当前K线索引（indicator_cache 用）
            strategy.current_idx = i

            try:
                # 兼容两种信号生成方式
                if hasattr(strategy, "generate_signal"):
                    window_start = max(0, i + 1 - max_window)
                    klines = self.candles[window_start:i + 1]
                    signal = strategy.generate_signal(
                        self.coin, klines,
                    )
                    if hasattr(signal, "signal"):
                        action = signal.signal.value
                    else:
                        action = signal.value if isinstance(signal, Signal) else signal
                else:
                    signal = strategy.get_signal(i)
                    action = signal.value if isinstance(signal, Signal) else signal
            except Exception:
                logger.exception("信号生成错误")
                action = "HOLD"

            current_price = closes[i]
            current_time = times[i]

            trade_capital = self._get_trade_capital()
            position_size = trade_capital * self.leverage  # 开仓总额

            # ===== BUY 持仓的移动止盈检测 =====
            if self.enable_ttp and position == "BUY" and self.balance[-1] > 0:
                # 使用统一的 TTP 管理器
                position_info = {
                    "coin": self.coin, "side": "LONG",
                    "entry_price": entry_price,
                }
                result = self.ttp_manager.check(
                    position=position_info,
                    current_price=highs[i] if self.ttp_highlow else current_price,
                    entry_price=entry_price,
                    position_side="LONG",
                )

                # TTP 触发
                if result.should_close:
                    ttp_price = result.ttp_level or current_price
                    raw_pnl = self._calc_raw_pnl(
                        entry_price, ttp_price,
                        position_size, "long",
                    )
                    holding = i - self._position_open_bar
                    fee, slip, fund = self._calc_trading_costs(
                        position_size, holding,
                        entry_price, ttp_price,
                    )
                    pnl = raw_pnl - fee - slip - fund
                    self.balance.append(self.balance[-1] + pnl)
                    new_balance = self.balance[-1]

                    # 检查提款
                    day_index = (i - start_idx) // self.bars_per_day
                    withdraw = self._check_withdraw(day_index)
                    if withdraw > 0:
                        self.balance[-1] = self.balance[-1] - withdraw
                        new_balance = self.balance[-1]

                    self.trades.append(Trade(
                        current_time, "TTP_CLOSE_BUY",
                        ttp_price, trade_capital, pnl,
                        new_balance, withdraw,
                        fee, slip, fund,
                    ))
                    self.trade_candle_indices.append(i)
                    self.current_balance = new_balance

                    position = "NO_POSITION"
                    self.ttp_manager.reset()
                    continue

            # ===== SELL 持仓的移动止盈检测 =====
            if self.enable_ttp and position == "SELL" and self.balance[-1] > 0:
                # 使用统一的 TTPManager 处理
                position_info = {
                    "coin": self.coin, "side": "SHORT",
                    "entry_price": entry_price,
                }
                result = self.ttp_manager.check(
                    position=position_info,
                    current_price=lows[i] if self.ttp_highlow else current_price,
                    entry_price=entry_price,
                    position_side="SHORT",
                )

                # TTP 触发
                if result.should_close:
                    ttp_price = result.ttp_level or current_price
                    raw_pnl = self._calc_raw_pnl(
                        entry_price, ttp_price,
                        position_size, "short",
                    )
                    holding = i - self._position_open_bar
                    fee, slip, fund = self._calc_trading_costs(
                        position_size, holding,
                        entry_price, ttp_price,
                    )
                    pnl = raw_pnl - fee - slip - fund
                    self.balance.append(self.balance[-1] + pnl)
                    new_balance = self.balance[-1]

                    # 检查提款
                    day_index = (i - start_idx) // self.bars_per_day
                    withdraw = self._check_withdraw(day_index)
                    if withdraw > 0:
                        self.balance[-1] = self.balance[-1] - withdraw
                        new_balance = self.balance[-1]

                    self.trades.append(Trade(
                        current_time, "TTP_CLOSE_SELL",
                        ttp_price, trade_capital, pnl,
                        new_balance, withdraw,
                        fee, slip, fund,
                    ))
                    self.trade_candle_indices.append(i)
                    self.current_balance = new_balance

                    position = "NO_POSITION"
                    self.ttp_manager.reset()
                    continue

            # 信号处理 - 按顺序检查
            # 0. CLOSE信号处理（平仓不反手，单向策略专用）
            if action == "CLOSE" and position != "NO_POSITION":
                if position == "BUY":
                    raw_pnl = self._calc_raw_pnl(
                        entry_price, current_price,
                        position_size, "long",
                    )
                    holding = i - self._position_open_bar
                    fee, slip, fund = self._calc_trading_costs(
                        position_size, holding,
                        entry_price, current_price,
                    )
                    pnl = raw_pnl - fee - slip - fund
                    self.balance.append(self.balance[-1] + pnl)
                    new_balance = self.balance[-1]

                    day_index = (i - start_idx) // self.bars_per_day
                    withdraw = self._check_withdraw(day_index)
                    if withdraw > 0:
                        self.balance[-1] = self.balance[-1] - withdraw
                        new_balance = self.balance[-1]

                    self.trades.append(Trade(
                        current_time, "CLOSE_BUY",
                        current_price, trade_capital, pnl,
                        new_balance, withdraw,
                        fee, slip, fund,
                    ))
                    self.trade_candle_indices.append(i)
                    self.current_balance = new_balance

                    if self.current_balance <= 0:
                        self.trades.append(Trade(
                            current_time, "LIQUIDATION",
                            current_price, 0, 0,
                            self.current_balance,
                        ))
                        self.trade_candle_indices.append(i)
                        self.balance.append(0)
                        position = "NO_POSITION"
                        break

                elif position == "SELL":
                    raw_pnl = self._calc_raw_pnl(
                        entry_price, current_price,
                        position_size, "short",
                    )
                    holding = i - self._position_open_bar
                    fee, slip, fund = self._calc_trading_costs(
