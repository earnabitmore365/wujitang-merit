#!/usr/bin/env python3
"""
报告种子重算 — 从 paired_trades 重新计算 combo_summary

@see ARCHITECTURE.md — 报告种子从 paired_trades 重算 combo_summary

增量回测后，paired_trades 新增了交易，需要重算汇总指标。
只重算有更新的 combo（通过 backtest_checkpoint.updated_at 判断）。

用法：
  python3 backtest/pipeline/refresh_summary.py                    # 重算所有有更新的 combo
  python3 backtest/pipeline/refresh_summary.py --all               # 强制重算全部
  python3 backtest/pipeline/refresh_summary.py --ttp               # TTP 版本
  python3 backtest/pipeline/refresh_summary.py --coins ETH XRP     # 只重算指定币种
"""

import sys
import os
import sqlite3
import logging
import argparse
import statistics
import time
from datetime import datetime
from typing import List, Dict, Optional

