}

_TIMEFRAME_MS = {
    '1m': 60_000, '5m': 300_000, '15m': 900_000, '30m': 1_800_000,
    '1h': 3_600_000, '2h': 7_200_000, '4h': 14_400_000,
    '8h': 28_800_000, '12h': 43_200_000, '1d': 86_400_000,
}


def _symbol_to_coin(symbol: str) -> str:
    """BTC/USDT → BTC, BTC/USD:BTC → BTC_COIN"""
    if ':' in symbol:
        return f"{symbol.split('/')[0]}_COIN"
    return symbol.split('/')[0]


def _download_coin(ex, symbol: str, timeframe: str, target: int) -> int:
    """单个币种单个周期的增量下载（断点续传）。"""
    coin = _symbol_to_coin(symbol)
    coin_dir = _HISTORICAL_DIR / coin
    coin_dir.mkdir(parents=True, exist_ok=True)
    out_file = coin_dir / f"{timeframe}.json"
    ms_per_bar = _TIMEFRAME_MS[timeframe]

    # 加载已有数据
    existing, existing_ts = [], set()
    if out_file.exists():
        try:
            data = json.loads(out_file.read_text())
            if data:
                existing = sorted(data, key=lambda d: d['time'])
                existing_ts = {d['time'] for d in existing}
        except (json.JSONDecodeError, KeyError):
            pass

    skip_backward = len(existing) >= target
    all_ohlcv = []

    # 币本位合约 API 限制查询跨度不超过 200 天
    # 1000条 × 8h = 333天 > 200天 → 减 limit
    is_delivery = ':' in symbol
    if is_delivery:
        max_bars = min(1000, int(199 * 86_400_000 / ms_per_bar))
    else:
        max_bars = 1000

    # 往前补历史
    if existing:
        oldest_ts = existing[0]['time']
    else:
        try:
            latest = ex.fetch_ohlcv(symbol, timeframe, limit=max_bars)
            if not latest:
                return 0
            all_ohlcv.extend(latest)
            oldest_ts = latest[0][0]
        except Exception as e:
            print(f"    初始拉取出错: {e}")
            return 0

    total_have = len(existing) + len(all_ohlcv)
    while not skip_backward and total_have < target:
        try:
            since = oldest_ts - (max_bars * ms_per_bar)
            ohlcv = ex.fetch_ohlcv(symbol, timeframe, since=since, limit=max_bars)
            if not ohlcv:
                break
            new_data = [c for c in ohlcv if c[0] < oldest_ts]
            if not new_data:
                break
            all_ohlcv = new_data + all_ohlcv
            oldest_ts = new_data[0][0]
            total_have = len(existing) + len(all_ohlcv)
            time.sleep(0.5 if timeframe == '1m' else 1.0)
        except Exception as e:
            print(f"    拉取出错: {e}")
            time.sleep(5)

    # 往后补最新
    if existing:
        newest_ts = existing[-1]['time']
        now_ms = int(time.time() * 1000)
        if now_ms - newest_ts > ms_per_bar * 2:
            since_fwd = newest_ts + ms_per_bar
            while since_fwd < now_ms:
                try:
                    ohlcv = ex.fetch_ohlcv(symbol, timeframe, since=since_fwd, limit=max_bars)
                    if not ohlcv:
                        break
                    new_fwd = [c for c in ohlcv if c[0] > newest_ts]
                    if not new_fwd:
                        break
                    all_ohlcv.extend(new_fwd)
                    since_fwd = new_fwd[-1][0] + ms_per_bar
                    newest_ts = new_fwd[-1][0]
                    time.sleep(0.5 if timeframe == '1m' else 1.0)
                except Exception as e:
                    print(f"    补充最新出错: {e}")
                    time.sleep(5)

    if not all_ohlcv and not existing:
        return 0

    # 合并去重排序
    merged = {d['time']: d for d in existing}
    for c in all_ohlcv:
        ts = c[0]
        if ts not in merged:
            merged[ts] = {"time": ts, "open": c[1], "high": c[2],
                          "low": c[3], "close": c[4], "volume": c[5]}

    result = sorted(merged.values(), key=lambda d: d['time'])
    if len(result) > target:
        result = result[-target:]

    out_file.write_text(json.dumps(result, separators=(',', ':')))
    added = len(result) - len(existing)
    if added > 0:
        first_d = ex.iso8601(result[0]['time'])[:10]
        last_d = ex.iso8601(result[-1]['time'])[:10]
        print(f"  {coin}/{timeframe}: {len(result):,} 条 ({first_d}~{last_d}) [+{added:,}]")
    return added


def download_all_coins() -> None:
    """阶段 0：从 Binance 增量下载 K 线到 data/historical/"""
    import ccxt

    print("=== 阶段 0：Binance 增量下载 ===")
    ex_spot = ccxt.binance({'enableRateLimit': True})
    ex_deliv = ccxt.binance({'enableRateLimit': True,
                             'options': {'defaultType': 'delivery'}})

    all_pairs = _USDT_PAIRS + _COIN_MARGINED_PAIRS
    print(f"交易对: {len(all_pairs)} 个, 周期: {len(_DOWNLOAD_TARGETS)} 个")

    if _COIN_MARGINED_PAIRS:
        print("加载币本位合约市场...")
        ex_deliv.load_markets()

    total_added = 0
    for tf, target in _DOWNLOAD_TARGETS.items():
        for symbol in all_pairs:
            ex = ex_deliv if ':' in symbol else ex_spot
            added = _download_coin(ex, symbol, tf, target)
            total_added += added

    print(f"阶段 0 完成，新增 {total_added:,} 条\n")


