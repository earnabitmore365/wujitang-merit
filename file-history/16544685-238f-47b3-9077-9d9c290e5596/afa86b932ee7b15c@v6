def import_json_to_duckdb(con: duckdb.DuckDBPyConnection) -> None:
    """将 data/historical/*.json 增量导入 klines 表。"""
    print("=== 阶段 0.5：JSON → klines.duckdb 导入 ===")

    if not _HISTORICAL_DIR.exists():
        print("  historical/ 目录不存在，跳过")
        return

    total_inserted = 0
    for coin_dir in sorted(_HISTORICAL_DIR.iterdir()):
        if not coin_dir.is_dir() or coin_dir.name.startswith('.'):
            continue
        coin = coin_dir.name

        for json_file in sorted(coin_dir.glob("*.json")):
            interval = json_file.stem
            data = json.loads(json_file.read_text())
            if not data:
                continue

            # 查 DB 里该 coin/interval 的最大 time
            row = con.execute(
                "SELECT MAX(time) FROM klines WHERE coin = ? AND interval = ?",
                [coin, interval],
            ).fetchone()
            existing_max = row[0] if row else None

            if existing_max:
                new_rows = [d for d in data if d["time"] > existing_max]
            else:
                new_rows = data

            if not new_rows:
                continue

            df = pd.DataFrame(new_rows)
            df["coin"] = coin
            df["interval"] = interval
            con.register("tmp_import", df)
            con.execute("""
                INSERT INTO klines (coin, interval, time, open, high, low, close, volume)
                SELECT coin, interval, time, open, high, low, close, volume
                FROM tmp_import
            """)
            con.unregister("tmp_import")
            con.commit()
            total_inserted += len(new_rows)
            print(f"  [导入] {coin}/{interval} +{len(new_rows):,} 行")

    if total_inserted == 0:
        print("  无新数据需要导入")
    else:
        print(f"  总计导入 {total_inserted:,} 行")
    print("阶段 0.5 完成\n")


