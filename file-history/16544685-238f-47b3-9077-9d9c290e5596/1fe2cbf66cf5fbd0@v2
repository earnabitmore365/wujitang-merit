## Python SDK — pybit

```bash
pip install pybit  # >= 5.14.0, Python >= 3.9.1
```

```python
from pybit.unified_trading import HTTP

session = HTTP(testnet=False, api_key="...", api_secret="...")

# K 线
session.get_kline(category="linear", symbol="BTCUSDT", interval=5, limit=200)

# 下单
session.place_order(
    category="linear", symbol="BTCUSDT",
    side="Buy", orderType="Limit",
    qty="0.01", price="25000",
    timeInForce="GTC", positionIdx=0,
)

# 持仓
session.get_positions(category="linear", symbol="BTCUSDT")

# 余额
session.get_wallet_balance(accountType="UNIFIED", coin="USDT")
```

