"""build_klines_indicators.py

两阶段构建脚本：
  1. 生成镜像 K线：将 klines 表中每组 (coin, interval) 价格取负，
     存为 {coin}_mirror 行。收益率自然反转，牛市变熊市。
  2. 计算指标：按 indicator_col_map.json，对所有组（含 _mirror）
     批量计算 101 个指标列，一次 UPDATE 写入，支持断点续传。

用法：
    python3 build_klines_indicators.py
"""

from __future__ import annotations

import json
import math
import os
import sys
import time
from pathlib import Path
from typing import Any

import pandas as pd
import duckdb

